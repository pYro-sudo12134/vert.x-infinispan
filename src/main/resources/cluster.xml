<?xml version="1.0" encoding="UTF-8"?>
<infinispan xmlns="urn:infinispan:config:14.0">

    <cache-container name="vertx-cluster-manager"
                     default-cache="default"
                     statistics="true">
        <transport stack="${jgroups.stack:tcp}"
                   node-name="${infinispan.node.name:}"
                   cluster="${infinispan.cluster.name:vertx-cluster}"/>

        <serialization>
            <context-initializer class="by.losik.meta.FileMetadataInitializerImpl"/>

        </serialization>

        <distributed-cache name="default">
            <encoding media-type="application/x-java-object"/>
        </distributed-cache>

        <distributed-cache name="file.metadata.indexed">
            <encoding media-type="application/x-protostream"/>
            <indexing storage="filesystem" path="${java.io.tmpdir:/tmp/infinispan-indexes}" startup-mode="auto">
                <indexed-entities>
                    <indexed-entity>by.losik.meta.FileMetadata</indexed-entity>
                </indexed-entities>
            </indexing>
        </distributed-cache>

        <replicated-cache name="__vertx.subs">
            <encoding media-type="application/x-java-object"/>
            <transaction mode="NON_XA" locking="PESSIMISTIC"/>
        </replicated-cache>

        <replicated-cache name="__vertx.haInfo">
            <encoding media-type="application/x-java-object"/>
            <transaction mode="NON_XA" locking="PESSIMISTIC"/>
        </replicated-cache>

        <replicated-cache name="__vertx.nodeInfo">
            <encoding media-type="application/x-java-object"/>
            <transaction mode="NON_XA" locking="PESSIMISTIC"/>
        </replicated-cache>

        <distributed-cache name="vertx-sync">
            <encoding media-type="application/x-java-object"/>
            <expiration lifespan="60000"
                        max-idle="30000"/>
        </distributed-cache>

        <replicated-cache name="vertx-subscription">
            <encoding media-type="application/x-java-object"/>
            <expiration lifespan="300000"
                        max-idle="60000"/>
        </replicated-cache>

        <distributed-cache name="vertx-locks">
            <encoding media-type="application/x-java-object"/>
            <transaction mode="NON_XA"/>
            <expiration lifespan="30000"
                        max-idle="10000"/>
        </distributed-cache>

        <distributed-cache-configuration name="__vertx.distributed.cache.configuration"/>

    </cache-container>
</infinispan>